<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="20261028-01" author="arquitecto-java">
        <createTable tableName="insumos">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="nombre" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="stock_actual" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="stock_minimo" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="activo" type="BIT" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="20261028-02" author="arquitecto-java">
        <insert tableName="insumos">
            <column name="nombre" value="Guantes de Látex Quirúrgicos M"/>
            <column name="stock_actual" valueNumeric="150"/>
            <column name="stock_minimo" valueNumeric="20"/>
            <column name="activo" valueNumeric="1"/>
        </insert>
    </changeSet>
</databaseChangeLog>