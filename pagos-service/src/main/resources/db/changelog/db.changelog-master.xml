<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="1" author="alumno">
        <createTable tableName="pagos">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="historial_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="monto" type="DECIMAL(10,2)">
                <constraints nullable="false"/>
            </column>
            <column name="metodo_pago" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="fecha_pago" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="completado" type="BIT" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="2" author="alumno">
        <insert tableName="pagos">
            <column name="historial_id" valueNumeric="1"/>
            <column name="monto" value="45000.00"/>
            <column name="metodo_pago" value="EFECTIVO"/>
            <column name="completado" valueNumeric="1"/>
        </insert>
    </changeSet>

