<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="1" author="alumno">
        <createTable tableName="tratamientos">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="nombre" type="VARCHAR(100)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="descripcion" type="VARCHAR(255)">
                <constraints nullable="true"/>
            </column>
            <column name="precio_base" type="DECIMAL(10,2)">
                <constraints nullable="false"/>
            </column>
            <column name="duracion_estimada_minutos" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="activo" type="BIT" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="2" author="alumno">
        <insert tableName="tratamientos">
            <column name="nombre" value="Limpieza Dental Profiláctica"/>
            <column name="descripcion" value="Remoción de cálculo dental y pulido coronario simple."/>
            <column name="precio_base" value="45000.00"/>
            <column name="duracion_estimada_minutos" value="30"/>
            <column name="activo" valueNumeric="1"/>
        </insert>
        <insert tableName="tratamientos">
            <column name="nombre" value="Restauración Resina Simple"/>
            <column name="descripcion" value="Obturación estética de composite."/>
            <column name="precio_base" value="55000.00"/>
            <column name="duracion_estimada_minutos" value="45"/>
            <column name="activo" valueNumeric="1"/>
        </insert>
    </changeSet>

    <changeSet id="3" author="alumno">
        <insert tableName="tratamientos">
            <column name="nombre" value="Extracción Dental Simple"/>
            <column name="descripcion" value="Extracción de pieza sin complicaciones quirúrgicas."/>
            <column name="precio_base" value="40000.00"/>
            <column name="duracion_estimada_minutos" value="30"/>
            <column name="activo" valueNumeric="1"/>
        </insert>
        <insert tableName="tratamientos">
            <column name="nombre" value="Blanqueamiento Dental Clínico"/>
            <column name="descripcion" value="Blanqueamiento con gel al 35% y activación LED."/>
            <column name="precio_base" value="120000.00"/>
            <column name="duracion_estimada_minutos" value="60"/>
            <column name="activo" valueNumeric="1"/>
        </insert>
        <insert tableName="tratamientos">
            <column name="nombre" value="Ortodoncia Metálica (mensualidad)"/>
            <column name="descripcion" value="Control mensual de ortodoncia con brackets metálicos."/>
            <column name="precio_base" value="35000.00"/>
            <column name="duracion_estimada_minutos" value="20"/>
            <column name="activo" valueNumeric="1"/>
        </insert>
        <insert tableName="tratamientos">
            <column name="nombre" value="Implante Dental Unitario"/>
            <column name="descripcion" value="Instalación de implante titanio con corona provisional."/>
            <column name="precio_base" value="800000.00"/>
            <column name="duracion_estimada_minutos" value="120"/>
            <column name="activo" valueNumeric="1"/>
        </insert>
    </changeSet>

</databaseChangeLog>
